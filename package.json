{
  "name": "battleborn-fighters",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @battleborn/web",
    "dev:match-service": "npm run dev --workspace @battleborn/match-service",
    "build": "npm run build --workspace @battleborn/web",
    "check": "npm run check --workspace @battleborn/game-core && npm run check --workspace @battleborn/content && npm run check --workspace @battleborn/match-service && npm run check --workspace @battleborn/web",
    "test": "npm run test --workspace @battleborn/game-core"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
